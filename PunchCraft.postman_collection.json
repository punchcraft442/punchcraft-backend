              "host": ["{{baseUrl}}"],
              "path": ["profiles", "fighters"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "keyword", "value": "", "disabled": true },
                { "key": "region", "value": "", "disabled": true },
                { "key": "city", "value": "", "disabled": true },
                { "key": "verificationTier", "value": "", "disabled": true },
                { "key": "weightClass", "value": "", "disabled": true },
                { "key": "sort", "value": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Fighter Profile",
          "request": {
            "method": "GET",
            "auth": { "type": "noauth" },
            "url": { "raw": "{{baseUrl}}/profiles/fighters/{{profileId}}", "host": ["{{baseUrl}}"], "path": ["profiles", "fighters", "{{profileId}}"] }
          }
        },
        {
          "name": "Update Fighter Profile",
          "request": {
            "method": "PATCH",
            "url": { "raw": "{{baseUrl}}/profiles/fighters/{{profileId}}", "host": ["{{baseUrl}}"], "path": ["profiles", "fighters", "{{profileId}}"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bio\": \"Updated bio.\",\n  \"weightClass\": \"welterweight\"\n}"
            }
          }
        },
        {
          "name": "Submit Fighter Profile",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/profiles/fighters/{{profileId}}/submit", "host": ["{{baseUrl}}"], "path": ["profiles", "fighters", "{{profileId}}", "submit"] }
          }
        },
        {
          "name": "Add Fight History",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/profiles/fighters/{{profileId}}/fight-history", "host": ["{{baseUrl}}"], "path": ["profiles", "fighters", "{{profileId}}", "fight-history"] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"opponentName\": \"Kofi Asare\",\n  \"eventName\": \"Accra Fight Night\",\n  \"eventDate\": \"2026-03-15\",\n  \"result\": \"win\",\n  \"method\": \"KO\",\n  \"round\": 4\n}"
            }
          }
        }
      ]
    },
