            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Kwame Mensah\",\n  \"ringName\": \"The Accra Lion\",\n  \"nationality\": \"Ghanaian\",\n  \"weightClass\": \"lightweight\",\n  \"stance\": \"orthodox\",\n  \"heightCm\": 175,\n  \"reachCm\": 178,\n  \"record\": { \"wins\": 10, \"losses\": 2, \"draws\": 0, \"kos\": 7 },\n  \"bio\": \"Professional boxer from Accra.\",\n  \"region\": \"Greater Accra\",\n  \"city\": \"Accra\"\n}"
            }
